<?xml version="1.0" encoding="utf-8"?>
<!-- Horizons launcher: teal sun setting on the horizon with a cloud above it.
     Bold solid fills, all teal on the near-black adaptive-icon backplate. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sun: half-circle sitting on the horizon line, lower-left of center -->
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M30,70 a18,18 0 0 1 36,0 Z" />

    <!-- Horizon line (thick) -->
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M14,70 H94 V74 H14 Z" />

    <!-- Horizon ripple just below -->
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M22,80 H56 V83 H22 Z" />
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M64,80 H86 V83 H64 Z" />

    <!-- Sun rays poking above the sun on the left side -->
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M28,48 l-8,-6 l2,-3 l8,6 z" />
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M40,40 l-3,-9 l3,-1 l3,9 z" />

    <!-- Cloud: bumpy puff upper-right, slightly overlapping/above the sun -->
    <path
        android:fillColor="#2DD4D9"
        android:pathData="M58,50 a8,8 0 0 1 16,0 a7,7 0 0 1 14,2 a6,6 0 0 1 -2,12 H58 a8,8 0 0 1 -8,-8 a8,8 0 0 1 8,-6 z" />
</vector>
