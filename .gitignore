# Gradle
.gradle/
build/
*/build/
!gradle/wrapper/gradle-wrapper.jar

# Claude Code session state (agent worktrees, local settings) — but
# hooks/settings ARE meant to be committed and shared across sessions,
# so carve those out explicitly.
.claude/*
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.json

# Android Studio / IntelliJ
.idea/
*.iml
captures/
.cxx/

# Local config & secrets (NEVER commit keys — see Architecture §12)
local.properties
*.keystore
!app/debug.keystore
!release/debug.keystore
*.jks
google-services.json
service-account*.json
secrets.properties

# On-device model weights — never committed (Architecture §4 / §7)
*.nexa
*.gguf

# Local-only AAR drops — large native libs stay in the repo so builds
# have zero external download dependencies.
# horizons/libs/  ← UN-IGNORED: sherpa-onnx-1.13.2.aar is committed

# OS
.DS_Store
Thumbs.db

# sherpa-onnx AAR — now committed directly (35 MB, arm64-v8a only)

# CI-generated: daemon binary copied into jniLibs by build-apk.yml, never committed
horizons/src/main/jniLibs/

# Logs / build artifacts
*.log
interaction_logs.jsonl
*.apk
*.aab

# Kotlin compiler session data (generated by local builds)
.kotlin/
