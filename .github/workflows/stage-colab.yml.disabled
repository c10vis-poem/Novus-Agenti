# DISABLED (session 13, 2026-07-03): renamed out of .yml so GitHub Actions
# won't pick it up. It hardcodes nbPath = 'notebooks/compile_qwen3_vl.ipynb'
# — wrong model name (repo's primary path is qwen3_5_9b) and no
# notebooks/ directory has ever existed in this repo. Would fire on any
# push touching scripts/compile_*.py and post a PR comment linking to a
# 404. Re-enable (rename back to .yml) once a real notebook exists at
# the corrected path, or rewrite nbPath.
name: stage-colab

# Auto-prepares a one-click Colab URL on the PR whenever a compile script or
# notebook changes. The PR body is updated in place between <!-- colab-stage -->
# markers so this never spams comments.

on:
  push:
    branches:
      - '**'
    paths:
      - 'notebooks/**'
      - 'scripts/compile_*.py'

permissions:
  contents: read
  pull-requests: write

jobs:
  stage-colab:
    runs-on: ubuntu-latest
    steps:
      - name: Find PR for this branch
        id: pr
        uses: actions/github-script@v7
        with:
          script: |
            const { owner, repo } = context.repo;
            const branch = context.ref.replace('refs/heads/', '');
            const prs = await github.rest.pulls.list({
              owner, repo, head: `${owner}:${branch}`, state: 'open',
            });
            if (prs.data.length === 0) {
              core.info(`No open PR for ${branch} — nothing to stage.`);
              core.setOutput('found', 'false');
              return;
            }
            const pr = prs.data[0];
            core.setOutput('found', 'true');
            core.setOutput('number', pr.number);
            core.setOutput('body', pr.body || '');
            core.setOutput('branch', branch);

      - name: Update PR body with Colab link
        if: steps.pr.outputs.found == 'true'
        uses: actions/github-script@v7
        env:
          PR_NUMBER: ${{ steps.pr.outputs.number }}
          PR_BODY: ${{ steps.pr.outputs.body }}
          BRANCH: ${{ steps.pr.outputs.branch }}
        with:
          script: |
            const { owner, repo } = context.repo;
            const number = Number(process.env.PR_NUMBER);
            const branch = process.env.BRANCH;
            const oldBody = process.env.PR_BODY || '';

            const nbPath = 'notebooks/compile_qwen3_vl.ipynb';
            const colabUrl =
              `https://colab.research.google.com/github/${owner}/${repo}/blob/${branch}/${nbPath}`;

            const block = [
              '<!-- colab-stage -->',
              '### Staged Colab compile',
              '',
              `[Open compile_qwen3_vl.ipynb in Colab](${colabUrl})`,
              '',
              `Branch: \`${branch}\` · Notebook: \`${nbPath}\``,
              'Tap → `Runtime → Run all`. Secrets needed in Colab: `HF_TOKEN`, `QAI_HUB_API_TOKEN`.',
              '<!-- /colab-stage -->',
            ].join('\n');

            const re = /<!-- colab-stage -->[\s\S]*?<!-- \/colab-stage -->/;
            const newBody = re.test(oldBody)
              ? oldBody.replace(re, block)
              : (oldBody ? `${oldBody}\n\n${block}` : block);

            if (newBody === oldBody) {
              core.info('PR body already up to date.');
              return;
            }
            await github.rest.pulls.update({ owner, repo, pull_number: number, body: newBody });
            core.info(`Updated PR #${number} with Colab link.`);
